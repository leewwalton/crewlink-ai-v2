{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CdkBootstrapSsm",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath"
      ],
      "Resource": "arn:aws:ssm:us-west-2:395333095307:parameter/cdk-bootstrap/*"
    },
    {
      "Sid": "CdkAssumeBootstrapRoles",
      "Effect": "Allow",
      "Action": "sts:AssumeRole",
      "Resource": [
        "arn:aws:iam::395333095307:role/cdk-hnb659fds-deploy-role-395333095307-us-west-2",
        "arn:aws:iam::395333095307:role/cdk-hnb659fds-file-publishing-role-395333095307-us-west-2",
        "arn:aws:iam::395333095307:role/cdk-hnb659fds-image-publishing-role-395333095307-us-west-2",
        "arn:aws:iam::395333095307:role/cdk-hnb659fds-lookup-role-395333095307-us-west-2"
      ]
    },
    {
      "Sid": "CdkPassBootstrapRoles",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::395333095307:role/cdk-hnb659fds-cfn-exec-role-395333095307-us-west-2",
        "arn:aws:iam::395333095307:role/cdk-hnb659fds-deploy-role-395333095307-us-west-2",
        "arn:aws:iam::395333095307:role/cdk-hnb659fds-file-publishing-role-395333095307-us-west-2",
        "arn:aws:iam::395333095307:role/cdk-hnb659fds-image-publishing-role-395333095307-us-west-2"
      ]
    },
    {
      "Sid": "CdkAssetBucket",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:ListBucket", "s3:GetBucketLocation"],
      "Resource": [
        "arn:aws:s3:::cdk-hnb659fds-assets-395333095307-us-west-2",
        "arn:aws:s3:::cdk-hnb659fds-assets-395333095307-us-west-2/*"
      ]
    },
    {
      "Sid": "CrewLinkCloudFormation",
      "Effect": "Allow",
      "Action": [
        "cloudformation:CreateChangeSet",
        "cloudformation:DeleteChangeSet",
        "cloudformation:DescribeChangeSet",
        "cloudformation:ExecuteChangeSet",
        "cloudformation:ListChangeSets",
        "cloudformation:DescribeStacks",
        "cloudformation:CreateStack",
        "cloudformation:UpdateStack",
        "cloudformation:DeleteStack",
        "cloudformation:ListStacks",
        "cloudformation:DescribeStackEvents",
        "cloudformation:DescribeStackResources",
        "cloudformation:GetTemplate",
        "cloudformation:GetTemplateSummary",
        "cloudformation:ValidateTemplate"
      ],
      "Resource": [
        "arn:aws:cloudformation:us-west-2:395333095307:stack/CrewLinkPipelineStack/*",
        "arn:aws:cloudformation:us-west-2:395333095307:stack/CDKToolkit/*"
      ]
    }
  ]
}
